<!-- envs/lab_scene.xml -->
<mujoco model="xarm6_rail_cubes_bins">

  <compiler angle="radian" meshdir="assets/"/>
  <option gravity="0 0 -9.81" timestep="0.002" integrator="implicitfast"/>

  <!-- Center the viewer on the working area (bench top, slightly forward of
       the rail) and pull the camera back enough to frame the whole arm. -->
  <statistic center="0 0.15 0.95" extent="1.8"/>

  <visual>
    <headlight ambient="0.4 0.4 0.4" diffuse="0.6 0.6 0.6"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <map zfar="30"/>
    <!-- azimuth=135 looks at the scene from the front-right; elevation=-25
         tilts the view ~25 deg down so the bench/cubes/bins are clearly visible. -->
    <global azimuth="135" elevation="-25" offwidth="1280" offheight="720"/>
  </visual>

  <default>
    <default class="arm_link">
      <geom contype="2" conaffinity="1"/>
    </default>
    <default class="cube">
      <geom type="box" size="0.015 0.015 0.015" mass="0.05"
            friction="1.0 0.05 0.0001" solref="0.005 1" solimp="0.95 0.99 0.001"/>
    </default>
    <default class="bin_wall">
      <geom type="box" rgba="0.8 0.8 0.8 0.5" mass="0"
            contype="1" conaffinity="1"/>
    </default>
    <default class="tube_body">
      <geom type="cylinder" size="0.015 0.0575" mass="0.05"
            friction="1.0 0.05 0.0001" solref="0.005 1" solimp="0.95 0.99 0.001"/>
    </default>
    <default class="rack_wall">
      <geom type="box" rgba="0.85 0.85 0.85 0.7" mass="0"
            contype="1" conaffinity="1"/>
    </default>
    <default class="rack_base">
      <geom type="box" rgba="0.6 0.6 0.6 1" mass="0"
            contype="1" conaffinity="1"/>
    </default>
    <!-- 96-well SBS plate. ~127 x 85 x 14 mm. Long dimension (127 mm)
         along Y so the plate fits within the OT-2 deck's column pitch
         (132 mm cols, 89 mm rows); the short dimension (85 mm) is
         along X (row direction). Modest mass so push/pick dynamics
         feel like a real plate rather than a paperweight. -->
    <default class="well_plate_body">
      <geom type="box" size="0.0425 0.0635 0.007" mass="0.10"
            friction="1.0 0.05 0.0001"
            solref="0.005 1" solimp="0.95 0.99 0.001"/>
    </default>
    <!-- OT-2 enclosure walls: COLLIDING. The arm must enter through
         the open front face (-x, facing the bench) -- it cannot pass
         through the polycarbonate sides, back, or top. The translucent
         appearance is purely cosmetic; the physics treats these as
         hard walls. -->
    <default class="ot2_wall">
      <geom type="box" rgba="0.85 0.92 1.0 0.18" mass="0"
            contype="1" conaffinity="1"/>
    </default>
    <!-- Opentrons-style tip rack (96-position SBS tip box). Slightly
         taller than a plate (tips contribute the bulk of the height). -->
    <default class="tip_box_body">
      <geom type="box" size="0.0425 0.0635 0.040" mass="0.20"
            friction="1.0 0.05 0.0001"
            solref="0.005 1" solimp="0.95 0.99 0.001"/>
    </default>
    <!-- Heater-shaker module (152 x 90 x 82mm). Heavy-ish; meant to
         stay put on the bench. Free body so it CAN be pushed in
         principle, but the LLM should usually leave it alone. -->
    <default class="heater_shaker_body">
      <geom type="box" size="0.076 0.045 0.041" mass="2.0"
            friction="1.0 0.05 0.0001"
            solref="0.005 1" solimp="0.95 0.99 0.001"/>
    </default>
  </default>

  <asset>
    <material name="red_mat"   rgba="0.9 0.2 0.2 1"/>
    <material name="green_mat" rgba="0.2 0.8 0.3 1"/>
    <material name="blue_mat"  rgba="0.2 0.4 0.9 1"/>
    <material name="red_bin_mat"   rgba="0.9 0.2 0.2 0.6"/>
    <material name="green_bin_mat" rgba="0.2 0.8 0.3 0.6"/>
    <material name="blue_bin_mat"  rgba="0.2 0.4 0.9 0.6"/>
    <!-- Falcon tube materials -->
    <material name="tube_body_mat"  rgba="0.95 0.95 0.95 0.5"/>
    <material name="cap_orange_mat" rgba="0.95 0.55 0.10 1"/>
    <material name="cap_blue_mat"   rgba="0.15 0.40 0.85 1"/>
    <!-- OT-2 instrument materials -->
    <material name="ot2_chassis_mat" rgba="0.95 0.95 0.95 1"/>
    <material name="ot2_deck_mat"    rgba="0.30 0.32 0.36 1"/>
    <material name="ot2_slot_mat"    rgba="0.55 0.55 0.60 1"/>
    <material name="ot2_frame_mat"   rgba="0.20 0.20 0.22 1"/>
    <material name="ot2_logo_mat"    rgba="0.10 0.50 0.85 1"/>
    <!-- 96-well plate material (dark blue, typical biology plate) -->
    <material name="well_plate_mat"  rgba="0.10 0.20 0.45 1"/>
    <material name="well_plate_top_mat" rgba="0.55 0.65 0.85 1"/>
    <!-- Tip box (Opentrons tip rack is typically white/grey) -->
    <material name="tip_box_mat"     rgba="0.92 0.92 0.94 1"/>
    <material name="tip_box_top_mat" rgba="0.45 0.45 0.50 1"/>
    <!-- Heater-shaker (Opentrons module is mostly dark grey with a blue accent) -->
    <material name="heater_shaker_mat"     rgba="0.20 0.22 0.26 1"/>
    <material name="heater_shaker_top_mat" rgba="0.30 0.32 0.36 1"/>
    <material name="heater_shaker_accent_mat" rgba="0.10 0.50 0.85 1"/>
  </asset>

  <worldbody>

    <light pos="0 0 2.5" dir="0 0 -1" diffuse="0.7 0.7 0.7"/>
    <light pos="0.5 0.5 1.8" dir="-0.3 -0.3 -1" diffuse="0.4 0.4 0.4"/>

    <geom name="floor" type="plane" size="3 3 0.1"
          rgba="0.7 0.7 0.65 1" contype="1" conaffinity="1"/>

    <body name="bench" pos="0 0 0.375">
      <geom name="bench_top" type="box" size="0.75 0.45 0.375"
            rgba="0.75 0.65 0.5 1" contype="1" conaffinity="1" mass="0"/>
    </body>

    <body name="rail_track" pos="0.0 -0.05 0.75">
      <geom name="rail_geom" type="box" size="0.35 0.025 0.015"
            rgba="0.4 0.4 0.45 1" contype="0" conaffinity="0" mass="0"/>

      <body name="rail_carriage" pos="-0.35 0.0 0.02">
        <joint name="rail" type="slide" axis="1 0 0"
               range="0.0 0.7" damping="200"/>
        <geom name="carriage_geom" type="box" size="0.06 0.04 0.015"
              rgba="0.55 0.55 0.6 1" contype="1" conaffinity="1" mass="2.0"/>

        <body name="xarm_base" pos="0 0 0.02">
          <geom name="base_link" type="cylinder" size="0.06 0.04"
                rgba="0.3 0.3 0.3 1" mass="0.5" class="arm_link"/>
          <joint name="joint1" type="hinge" axis="0 0 1"
                 range="-3.14159 3.14159" damping="10"/>

          <body name="link1" pos="0 0 0.09">
            <geom name="link1_geom" type="box" size="0.055 0.055 0.11"
                  rgba="0.85 0.85 0.85 1" mass="2.16" class="arm_link"/>
            <joint name="joint2" type="hinge" axis="0 1 0"
                   range="-2.0944 2.0944" damping="10"/>

            <body name="link2" pos="0 0 0.22">
              <geom name="link2_geom" type="box" size="0.045 0.045 0.105"
                    rgba="0.85 0.85 0.85 1" mass="1.71" class="arm_link"/>
              <joint name="joint3" type="hinge" axis="0 1 0"
                     range="-3.14159 1.2217" damping="8"/>

              <body name="link3" pos="0 0 0.20">
                <geom name="link3_geom" type="box" size="0.04 0.04 0.09"
                      rgba="0.8 0.8 0.8 1" mass="1.38" class="arm_link"/>
                <joint name="joint4" type="hinge" axis="1 0 0"
                       range="-1.9199 1.9199" damping="6"/>

                <body name="link4" pos="0 0 0.175">
                  <geom name="link4_geom" type="box" size="0.035 0.035 0.075"
                        rgba="0.75 0.75 0.75 1" mass="1.05" class="arm_link"/>
                  <joint name="joint5" type="hinge" axis="0 1 0"
                         range="-2.6180 2.6180" damping="4"/>

                  <body name="link5" pos="0 0 0.13">
                    <geom name="link5_geom" type="box" size="0.03 0.03 0.055"
                          rgba="0.7 0.7 0.7 1" mass="0.72" class="arm_link"/>
                    <joint name="joint6" type="hinge" axis="1 0 0"
                           range="-1.9199 1.9199" damping="3"/>

                    <body name="link6" pos="0 0 0.075">
                      <geom name="link6_geom" type="cylinder" size="0.025 0.03"
                            rgba="0.6 0.6 0.6 1" mass="0.25" class="arm_link"/>
                      <!-- IK target marker. Kept small + translucent so it's an
                           unobtrusive cue rather than dominating the visual. -->
                      <site name="end_effector" pos="0 0 0.09"
                            size="0.005" rgba="1 0.3 0.3 0.5" type="sphere"/>
                      <body name="gripper" pos="0 0 0.06">
                        <!-- Palm: the static wrist plate. Geom name preserved
                             for FK validator (ARM_GEOM_NAMES) + weld targets. -->
                        <geom name="gripper_geom" type="box"
                              size="0.018 0.025 0.020"
                              pos="0 0 0.005"
                              rgba="0.35 0.35 0.35 1" mass="0.15"
                              class="arm_link"/>
                        <!-- Two parallel fingers extending past the EE site.
                             contype/conaffinity=0 makes them cosmetic-only (no
                             contacts), so adding them doesn't change physics
                             or invalidate existing IK trajectories. Welds
                             still do the actual grasping. Each joint qpos in
                             [0, 0.015] m: 0 = open, 0.015 = closed (inward). -->
                        <body name="finger_left" pos="0 -0.025 0.045">
                          <joint name="finger_left_joint" type="slide"
                                 axis="0 1 0" range="0 0.015" damping="2"/>
                          <geom name="finger_left_geom" type="box"
                                size="0.005 0.004 0.020"
                                rgba="0.2 0.2 0.2 1" mass="0.02"
                                contype="0" conaffinity="0"/>
                        </body>
                        <body name="finger_right" pos="0 0.025 0.045">
                          <joint name="finger_right_joint" type="slide"
                                 axis="0 -1 0" range="0 0.015" damping="2"/>
                          <geom name="finger_right_geom" type="box"
                                size="0.005 0.004 0.020"
                                rgba="0.2 0.2 0.2 1" mass="0.02"
                                contype="0" conaffinity="0"/>
                        </body>
                      </body>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>

      </body>
    </body>

    <!-- Cubes -->
    <body name="red_cube" pos="-0.20 0.15 0.78">
      <geom name="red_cube_geom" class="cube" material="red_mat"/>
      <joint type="free" name="red_cube_joint"/>
    </body>
    <body name="green_cube" pos="0.00 0.15 0.78">
      <geom name="green_cube_geom" class="cube" material="green_mat"/>
      <joint type="free" name="green_cube_joint"/>
    </body>
    <body name="blue_cube" pos="0.20 0.15 0.78">
      <geom name="blue_cube_geom" class="cube" material="blue_mat"/>
      <joint type="free" name="blue_cube_joint"/>
    </body>

    <!-- Bins -->
    <!-- Bins are now FREE bodies so push_object can move them. Mass 0.5kg
         per bin -- heavy enough not to bounce around when cubes are dropped
         inside, light enough for the arm to push around. -->
    <body name="red_bin" pos="-0.20 0.35 0.75">
      <inertial pos="0 0 0.020" mass="0.5" diaginertia="6e-4 6e-4 9e-4"/>
      <joint type="free" name="red_bin_joint"/>
      <geom name="red_bin_floor" type="box" size="0.040 0.040 0.001"
            pos="0 0 0.001" material="red_bin_mat"
            contype="1" conaffinity="1" mass="0"/>
      <geom name="red_bin_w_front" class="bin_wall"
            size="0.040 0.002 0.030" pos="0 -0.040 0.030"/>
      <geom name="red_bin_w_back"  class="bin_wall"
            size="0.040 0.002 0.030" pos="0  0.040 0.030"/>
      <geom name="red_bin_w_left"  class="bin_wall"
            size="0.002 0.040 0.030" pos="-0.040 0 0.030"/>
      <geom name="red_bin_w_right" class="bin_wall"
            size="0.002 0.040 0.030" pos=" 0.040 0 0.030"/>
    </body>

    <body name="green_bin" pos="0.00 0.35 0.75">
      <inertial pos="0 0 0.020" mass="0.5" diaginertia="6e-4 6e-4 9e-4"/>
      <joint type="free" name="green_bin_joint"/>
      <geom name="green_bin_floor" type="box" size="0.040 0.040 0.001"
            pos="0 0 0.001" material="green_bin_mat"
            contype="1" conaffinity="1" mass="0"/>
      <geom name="green_bin_w_front" class="bin_wall"
            size="0.040 0.002 0.030" pos="0 -0.040 0.030"/>
      <geom name="green_bin_w_back"  class="bin_wall"
            size="0.040 0.002 0.030" pos="0  0.040 0.030"/>
      <geom name="green_bin_w_left"  class="bin_wall"
            size="0.002 0.040 0.030" pos="-0.040 0 0.030"/>
      <geom name="green_bin_w_right" class="bin_wall"
            size="0.002 0.040 0.030" pos=" 0.040 0 0.030"/>
    </body>

    <body name="blue_bin" pos="0.20 0.35 0.75">
      <inertial pos="0 0 0.020" mass="0.5" diaginertia="6e-4 6e-4 9e-4"/>
      <joint type="free" name="blue_bin_joint"/>
      <geom name="blue_bin_floor" type="box" size="0.040 0.040 0.001"
            pos="0 0 0.001" material="blue_bin_mat"
            contype="1" conaffinity="1" mass="0"/>
      <geom name="blue_bin_w_front" class="bin_wall"
            size="0.040 0.002 0.030" pos="0 -0.040 0.030"/>
      <geom name="blue_bin_w_back"  class="bin_wall"
            size="0.040 0.002 0.030" pos="0  0.040 0.030"/>
      <geom name="blue_bin_w_left"  class="bin_wall"
            size="0.002 0.040 0.030" pos="-0.040 0 0.030"/>
      <geom name="blue_bin_w_right" class="bin_wall"
            size="0.002 0.040 0.030" pos=" 0.040 0 0.030"/>
    </body>

    <!-- ============================================================
         FALCON TUBE RACKS (2 racks x 8 slots each in a 4-col x 2-row grid)
         Currently populated with 3 tubes per rack, scattered across the grid
         so empty slots are visible.

         Grid layout (rack-local coords; rack centered at its body origin):
           Columns at x = -0.060, -0.020, +0.020, +0.060  (40mm pitch)
           Rows    at y = -0.020, +0.020                 (40mm pitch)
           => slot internal size 32 x 32 mm (room for 30 mm OD tubes)

         Construction: shared walls. Outer perimeter (4) + internal vertical
         separators between columns (3) + internal horizontal separator between
         rows (1) = 8 wall geoms per rack. Walls are 50mm tall.

         Tube specs: 30mm OD x 115mm body, 31mm cap x 12mm, body center at
         rack-frame z = 0.0625 (tube bottom rests on base plate top).
    ============================================================ -->

    <!-- LEFT RACK at x=-0.45, y=0.15. Holds L1, L2, L3 scattered across slots.
         Free body so it can be pushed (mass ~250g). -->
    <body name="left_tube_rack" pos="-0.45 0.15 0.755">
      <inertial pos="0 0 0.020" mass="0.25" diaginertia="3e-4 7e-4 8e-4"/>
      <joint type="free" name="left_tube_rack_joint"/>
      <geom name="left_rack_base" class="rack_base" size="0.085 0.045 0.005"
            pos="0 0 0"/>
      <!-- Outer perimeter -->
      <geom name="L_outer_front" class="rack_wall" size="0.080 0.001 0.025" pos=" 0.000 -0.040 0.030"/>
      <geom name="L_outer_back"  class="rack_wall" size="0.080 0.001 0.025" pos=" 0.000  0.040 0.030"/>
      <geom name="L_outer_left"  class="rack_wall" size="0.001 0.040 0.025" pos="-0.080  0.000 0.030"/>
      <geom name="L_outer_right" class="rack_wall" size="0.001 0.040 0.025" pos=" 0.080  0.000 0.030"/>
      <!-- Internal vertical separators (3, between the 4 columns) -->
      <geom name="L_sep_v1" class="rack_wall" size="0.001 0.040 0.025" pos="-0.040 0 0.030"/>
      <geom name="L_sep_v2" class="rack_wall" size="0.001 0.040 0.025" pos=" 0.000 0 0.030"/>
      <geom name="L_sep_v3" class="rack_wall" size="0.001 0.040 0.025" pos=" 0.040 0 0.030"/>
      <!-- Internal horizontal separator (1, between the 2 rows) -->
      <geom name="L_sep_h1" class="rack_wall" size="0.080 0.001 0.025" pos="0 0 0.030"/>
    </body>

    <!-- RIGHT RACK at x=+0.45, y=0.15. Holds R1, R2, R3.
         Free body (same as left). -->
    <body name="right_tube_rack" pos="0.45 0.15 0.755">
      <inertial pos="0 0 0.020" mass="0.25" diaginertia="3e-4 7e-4 8e-4"/>
      <joint type="free" name="right_tube_rack_joint"/>
      <geom name="right_rack_base" class="rack_base" size="0.085 0.045 0.005"
            pos="0 0 0"/>
      <geom name="R_outer_front" class="rack_wall" size="0.080 0.001 0.025" pos=" 0.000 -0.040 0.030"/>
      <geom name="R_outer_back"  class="rack_wall" size="0.080 0.001 0.025" pos=" 0.000  0.040 0.030"/>
      <geom name="R_outer_left"  class="rack_wall" size="0.001 0.040 0.025" pos="-0.080  0.000 0.030"/>
      <geom name="R_outer_right" class="rack_wall" size="0.001 0.040 0.025" pos=" 0.080  0.000 0.030"/>
      <geom name="R_sep_v1" class="rack_wall" size="0.001 0.040 0.025" pos="-0.040 0 0.030"/>
      <geom name="R_sep_v2" class="rack_wall" size="0.001 0.040 0.025" pos=" 0.000 0 0.030"/>
      <geom name="R_sep_v3" class="rack_wall" size="0.001 0.040 0.025" pos=" 0.040 0 0.030"/>
      <geom name="R_sep_h1" class="rack_wall" size="0.080 0.001 0.025" pos="0 0 0.030"/>
    </body>

    <!-- TUBES — free bodies. 3 per rack, scattered across the 4x2 grid.
         Left rack slots: L1@(col1,row1), L2@(col2,row2), L3@(col4,row1)
         Right rack slots: R1@(col1,row2), R2@(col3,row1), R3@(col4,row2)
         Columns: rel x ∈ {-0.06, -0.02, +0.02, +0.06}
         Rows:    rel y ∈ {-0.02 (front), +0.02 (back)} -->
    <!-- LEFT RACK TUBES -->
    <body name="tube_L1" pos="-0.510 0.130 0.8175">  <!-- col1 row1, orange -->
      <inertial pos="0 0 0.01" mass="0.03" diaginertia="3e-5 3e-5 5e-6"/>
      <geom name="tube_L1_body" class="tube_body" material="tube_body_mat" mass="0"/>
      <geom name="tube_L1_cap"  type="cylinder" size="0.0155 0.006"
            pos="0 0 0.0635" material="cap_orange_mat" mass="0"/>
      <joint type="free" name="tube_L1_joint"/>
    </body>
    <body name="tube_L2" pos="-0.470 0.170 0.8175">  <!-- col2 row2, blue -->
      <inertial pos="0 0 0.01" mass="0.03" diaginertia="3e-5 3e-5 5e-6"/>
      <geom name="tube_L2_body" class="tube_body" material="tube_body_mat" mass="0"/>
      <geom name="tube_L2_cap"  type="cylinder" size="0.0155 0.006"
            pos="0 0 0.0635" material="cap_blue_mat" mass="0"/>
      <joint type="free" name="tube_L2_joint"/>
    </body>
    <body name="tube_L3" pos="-0.390 0.130 0.8175">  <!-- col4 row1, orange -->
      <inertial pos="0 0 0.01" mass="0.03" diaginertia="3e-5 3e-5 5e-6"/>
      <geom name="tube_L3_body" class="tube_body" material="tube_body_mat" mass="0"/>
      <geom name="tube_L3_cap"  type="cylinder" size="0.0155 0.006"
            pos="0 0 0.0635" material="cap_orange_mat" mass="0"/>
      <joint type="free" name="tube_L3_joint"/>
    </body>
    <!-- RIGHT RACK TUBES -->
    <body name="tube_R1" pos="0.390 0.170 0.8175">   <!-- col1 row2, blue -->
      <inertial pos="0 0 0.01" mass="0.03" diaginertia="3e-5 3e-5 5e-6"/>
      <geom name="tube_R1_body" class="tube_body" material="tube_body_mat" mass="0"/>
      <geom name="tube_R1_cap"  type="cylinder" size="0.0155 0.006"
            pos="0 0 0.0635" material="cap_blue_mat" mass="0"/>
      <joint type="free" name="tube_R1_joint"/>
    </body>
    <body name="tube_R2" pos="0.470 0.130 0.8175">   <!-- col3 row1, orange -->
      <inertial pos="0 0 0.01" mass="0.03" diaginertia="3e-5 3e-5 5e-6"/>
      <geom name="tube_R2_body" class="tube_body" material="tube_body_mat" mass="0"/>
      <geom name="tube_R2_cap"  type="cylinder" size="0.0155 0.006"
            pos="0 0 0.0635" material="cap_orange_mat" mass="0"/>
      <joint type="free" name="tube_R2_joint"/>
    </body>
    <body name="tube_R3" pos="0.510 0.170 0.8175">   <!-- col4 row2, blue -->
      <inertial pos="0 0 0.01" mass="0.03" diaginertia="3e-5 3e-5 5e-6"/>
      <geom name="tube_R3_body" class="tube_body" material="tube_body_mat" mass="0"/>
      <geom name="tube_R3_cap"  type="cylinder" size="0.0155 0.006"
            pos="0 0 0.0635" material="cap_blue_mat" mass="0"/>
      <joint type="free" name="tube_R3_joint"/>
    </body>

    <!-- =============================================================
         OPENTRONS OT-2 (static fixture, not actuated).

         Real outer dimensions: 630 W x 570 D x 660 H mm (from the
         official spec). In this sim the chassis is taller than real
         because the deck is held at bench height (z=0.755 m) for arm
         reachability -- imagine the OT-2 sitting on its own riser
         table. The enclosure above the deck is 500 mm tall instead
         of the real 230 mm, again to give the arm vertical clearance
         when it extends in through the front opening.

         Side walls + back wall + top are COLLIDING obstacles. Front
         face (-x, toward bench) is open. The arm must approach from
         the bench side; it cannot pass through any other face.

         Deck layout: 11 SBS slots in a 3 col x 4 row grid + TRASH at
         slot 12 (back-right corner). Numbering matches the Opentrons
         convention: 1-3 = front row (closest to bench), 4-6, 7-9,
         then 10-11 + TRASH at the back. Slot pitch is 132 mm (cols)
         x 89 mm (rows).

         Coordinate convention: OT-2 body at world (1.0, 0, 0); deck
         top surface at z=0.755; "front of deck" = -x in OT-2 local
         (= world x < 1.0). When the arm looks at the OT-2 from the
         bench (looking +x), its LEFT corresponds to OT-2 local +y.
    ============================================================= -->
    <body name="opentrons_ot2" pos="1.0 0.0 0.0">
      <!-- Chassis: solid box from z=0 to z=0.750. Visually represents
           the OT-2 base + riser table; functionally just an obstacle
           the arm can't pass through. Half-extents 0.315 x 0.285 x 0.375. -->
      <geom name="ot2_chassis" type="box" size="0.315 0.285 0.375"
            pos="0 0 0.375" material="ot2_chassis_mat"
            contype="1" conaffinity="1" mass="0"/>
      <!-- Deck plate: dark grey, 5mm thick, sits on the chassis top.
           Slightly inset (5mm) from chassis edge for a clean look. -->
      <geom name="ot2_deck" type="box" size="0.310 0.280 0.0025"
            pos="0 0 0.7525" material="ot2_deck_mat"
            contype="1" conaffinity="1" mass="0"/>

      <!-- Slot markers: 3 cols x 4 rows + TRASH (= 12 positions).
           Each marker is a thin coloured rectangle on the deck.
           Visual only (non-colliding) so plates resting in slots
           don't catch on the marker geometry.
           Col offsets (local y): +0.132, 0, -0.132 (left, mid, right
           from the arm's POV looking +x toward the OT-2).
           Row offsets (local x): -0.133, -0.044, +0.044, +0.133
           (front, mid-front, mid-back, back). -->
      <geom name="ot2_slot_1"  type="box" size="0.064 0.043 0.0010"
            pos="-0.133 +0.132 0.755" material="ot2_slot_mat"
            contype="0" conaffinity="0" mass="0"/>
      <geom name="ot2_slot_2"  type="box" size="0.064 0.043 0.0010"
            pos="-0.133  0.000 0.755" material="ot2_slot_mat"
            contype="0" conaffinity="0" mass="0"/>
      <geom name="ot2_slot_3"  type="box" size="0.064 0.043 0.0010"
            pos="-0.133 -0.132 0.755" material="ot2_slot_mat"
            contype="0" conaffinity="0" mass="0"/>
      <geom name="ot2_slot_4"  type="box" size="0.064 0.043 0.0010"
            pos="-0.044 +0.132 0.755" material="ot2_slot_mat"
            contype="0" conaffinity="0" mass="0"/>
      <geom name="ot2_slot_5"  type="box" size="0.064 0.043 0.0010"
            pos="-0.044  0.000 0.755" material="ot2_slot_mat"
            contype="0" conaffinity="0" mass="0"/>
      <geom name="ot2_slot_6"  type="box" size="0.064 0.043 0.0010"
            pos="-0.044 -0.132 0.755" material="ot2_slot_mat"
            contype="0" conaffinity="0" mass="0"/>
      <geom name="ot2_slot_7"  type="box" size="0.064 0.043 0.0010"
            pos="+0.044 +0.132 0.755" material="ot2_slot_mat"
            contype="0" conaffinity="0" mass="0"/>
      <geom name="ot2_slot_8"  type="box" size="0.064 0.043 0.0010"
            pos="+0.044  0.000 0.755" material="ot2_slot_mat"
            contype="0" conaffinity="0" mass="0"/>
      <geom name="ot2_slot_9"  type="box" size="0.064 0.043 0.0010"
            pos="+0.044 -0.132 0.755" material="ot2_slot_mat"
            contype="0" conaffinity="0" mass="0"/>
      <geom name="ot2_slot_10" type="box" size="0.064 0.043 0.0010"
            pos="+0.133 +0.132 0.755" material="ot2_slot_mat"
            contype="0" conaffinity="0" mass="0"/>
      <geom name="ot2_slot_11" type="box" size="0.064 0.043 0.0010"
            pos="+0.133  0.000 0.755" material="ot2_slot_mat"
            contype="0" conaffinity="0" mass="0"/>
      <geom name="ot2_slot_trash" type="box" size="0.064 0.043 0.0010"
            pos="+0.133 -0.132 0.755" material="ot2_frame_mat"
            contype="0" conaffinity="0" mass="0"/>

      <!-- Enclosure walls: COLLIDING. Side walls + back wall + top.
           Front face (-x) intentionally absent -- that's the access
           opening for the arm. Wall extents are 0.250 vertical
           half-extent (500 mm enclosure height), thin (5mm) in the
           normal direction. -->
      <geom name="ot2_back_wall"  class="ot2_wall"
            size="0.005 0.285 0.250" pos="+0.315 0.000 1.005"/>
      <geom name="ot2_left_wall"  class="ot2_wall"
            size="0.315 0.005 0.250" pos="0.000 +0.285 1.005"/>
      <geom name="ot2_right_wall" class="ot2_wall"
            size="0.315 0.005 0.250" pos="0.000 -0.285 1.005"/>
      <geom name="ot2_top"        class="ot2_wall"
            size="0.315 0.285 0.005" pos="0.000 0.000 1.260"/>

      <!-- Front frame trim (visual only, non-colliding): thin top
           edge + corner posts at the open face so it reads as an
           "open-front box" rather than "missing wall". -->
      <geom name="ot2_front_top" type="box" size="0.005 0.285 0.025"
            pos="-0.315 0.000 1.230" material="ot2_frame_mat"
            contype="0" conaffinity="0" mass="0"/>
      <geom name="ot2_front_post_l" type="box" size="0.005 0.005 0.250"
            pos="-0.315 +0.285 1.005" material="ot2_frame_mat"
            contype="0" conaffinity="0" mass="0"/>
      <geom name="ot2_front_post_r" type="box" size="0.005 0.005 0.250"
            pos="-0.315 -0.285 1.005" material="ot2_frame_mat"
            contype="0" conaffinity="0" mass="0"/>
      <!-- Logo strip (blue band on the front top edge) -->
      <geom name="ot2_logo_strip" type="box" size="0.005 0.060 0.012"
            pos="-0.320 0.000 1.210" material="ot2_logo_mat"
            contype="0" conaffinity="0" mass="0"/>
    </body>

    <!-- 96-well plate A: sits in OT-2 slot 1 (front-left) at session
         start. World (0.867, +0.132, 0.7625) = OT-2 origin + slot 1
         offset + plate half-thickness. -->
    <body name="well_plate_A" pos="0.867 +0.132 0.7625">
      <inertial pos="0 0 0" mass="0.10" diaginertia="2e-4 2e-4 3e-4"/>
      <geom name="well_plate_A_body" class="well_plate_body"
            material="well_plate_mat"/>
      <geom name="well_plate_A_top" type="box" size="0.038 0.058 0.0015"
            pos="0 0 0.0085" material="well_plate_top_mat" mass="0"
            contype="0" conaffinity="0"/>
      <joint type="free" name="well_plate_A_joint"/>
    </body>

    <!-- 96-well plate B: sits on the bench at the front, between
         the bench's tube racks. Free body so the arm can pick it up
         and place it elsewhere (e.g. on the heater_shaker or on the
         OT-2 deck). -->
    <body name="well_plate_B" pos="+0.200 -0.300 0.7625">
      <inertial pos="0 0 0" mass="0.10" diaginertia="2e-4 2e-4 3e-4"/>
      <geom name="well_plate_B_body" class="well_plate_body"
            material="well_plate_mat"/>
      <geom name="well_plate_B_top" type="box" size="0.038 0.058 0.0015"
            pos="0 0 0.0085" material="well_plate_top_mat" mass="0"
            contype="0" conaffinity="0"/>
      <joint type="free" name="well_plate_B_joint"/>
    </body>

    <!-- Tip box: standard SBS tip rack (127 x 85 x 80 mm). Sits in
         OT-2 slot 4 (mid-front-left). Free body so the arm can pick
         it up and move it. -->
    <body name="tip_box" pos="0.956 +0.132 0.795">
      <inertial pos="0 0 0" mass="0.20" diaginertia="3e-4 3e-4 4e-4"/>
      <geom name="tip_box_body" class="tip_box_body"
            material="tip_box_mat"/>
      <!-- Cosmetic top to read as "tip rack grid". -->
      <geom name="tip_box_top" type="box" size="0.038 0.058 0.0015"
            pos="0 0 0.041" material="tip_box_top_mat" mass="0"
            contype="0" conaffinity="0"/>
      <joint type="free" name="tip_box_joint"/>
    </body>

    <!-- Opentrons Heater-Shaker module (152 W x 90 D x 82 H mm).
         Sits on the bench, front-left. Heavy (2 kg) so it stays put
         unless deliberately pushed. The flat top is a plate-sized
         surface the arm can place a 96-well plate onto. -->
    <body name="heater_shaker" pos="-0.300 -0.250 0.791">
      <inertial pos="0 0 0" mass="2.0" diaginertia="3e-3 3e-3 5e-3"/>
      <geom name="heater_shaker_body" class="heater_shaker_body"
            material="heater_shaker_mat"/>
      <!-- Flat shaker platform on top (slightly recessed). -->
      <geom name="heater_shaker_platform" type="box"
            size="0.070 0.043 0.002" pos="0 0 0.043"
            material="heater_shaker_top_mat" mass="0"
            contype="1" conaffinity="1"/>
      <!-- Blue accent strip on the front face (signature Opentrons look). -->
      <geom name="heater_shaker_logo" type="box"
            size="0.030 0.001 0.008" pos="0 -0.046 0.030"
            material="heater_shaker_accent_mat" mass="0"
            contype="0" conaffinity="0"/>
      <joint type="free" name="heater_shaker_joint"/>
    </body>

  </worldbody>

  <contact>
    <exclude body1="rail_carriage" body2="xarm_base"/>
    <exclude body1="rail_carriage" body2="link1"/>
    <exclude body1="xarm_base"     body2="link1"/>
    <exclude body1="link1"         body2="link2"/>
    <exclude body1="link2"         body2="link3"/>
    <exclude body1="link3"         body2="link4"/>
    <exclude body1="link4"         body2="link5"/>
    <exclude body1="link5"         body2="link6"/>
    <exclude body1="link6"         body2="gripper"/>
  </contact>

  <!-- ============================================================
       MAGNETIC-GRIPPER WELDS (runtime-toggled).
       Inactive by default. SimXArmAPI activates the weld for the
       cube nearest the gripper on gripper_close(), deactivates all
       on gripper_open(). Locks the cube-gripper relative pose so
       the cube is "carried" while the weld is active.
  ============================================================ -->
  <equality>
    <weld name="grip_red_cube"   body1="gripper" body2="red_cube"   active="false"/>
    <weld name="grip_green_cube" body1="gripper" body2="green_cube" active="false"/>
    <weld name="grip_blue_cube"  body1="gripper" body2="blue_cube"  active="false"/>
    <weld name="grip_tube_L1"    body1="gripper" body2="tube_L1"    active="false"/>
    <weld name="grip_tube_L2"    body1="gripper" body2="tube_L2"    active="false"/>
    <weld name="grip_tube_L3"    body1="gripper" body2="tube_L3"    active="false"/>
    <weld name="grip_tube_R1"    body1="gripper" body2="tube_R1"    active="false"/>
    <weld name="grip_tube_R2"    body1="gripper" body2="tube_R2"    active="false"/>
    <weld name="grip_tube_R3"    body1="gripper" body2="tube_R3"    active="false"/>
    <weld name="grip_red_bin"    body1="gripper" body2="red_bin"    active="false"/>
    <weld name="grip_green_bin"  body1="gripper" body2="green_bin"  active="false"/>
    <weld name="grip_blue_bin"   body1="gripper" body2="blue_bin"   active="false"/>
    <weld name="grip_left_rack"  body1="gripper" body2="left_tube_rack"  active="false"/>
    <weld name="grip_right_rack" body1="gripper" body2="right_tube_rack" active="false"/>
    <weld name="grip_well_plate_A" body1="gripper" body2="well_plate_A" active="false"/>
    <weld name="grip_well_plate_B" body1="gripper" body2="well_plate_B" active="false"/>
    <weld name="grip_tip_box"      body1="gripper" body2="tip_box"      active="false"/>
    <weld name="grip_heater_shaker" body1="gripper" body2="heater_shaker" active="false"/>
  </equality>

  <actuator>
    <position name="act_rail" joint="rail"   kp="2000" kv="200"/>
    <position name="act1"     joint="joint1" kp="500"  kv="50"/>
    <position name="act2"     joint="joint2" kp="500"  kv="50"/>
    <position name="act3"     joint="joint3" kp="400"  kv="40"/>
    <position name="act4"     joint="joint4" kp="300"  kv="30"/>
    <position name="act5"     joint="joint5" kp="200"  kv="20"/>
    <position name="act6"     joint="joint6" kp="150"  kv="15"/>
    <!-- Cosmetic finger actuators. ctrl in [0, 0.015] m: 0 = open, 0.015 =
         closed. SimXArmAPI drives both to the same value from gripper_close/
         gripper_open, so they always move in sync. -->
    <position name="act_finger_l" joint="finger_left_joint"
              kp="200" kv="20" ctrlrange="0 0.015"/>
    <position name="act_finger_r" joint="finger_right_joint"
              kp="200" kv="20" ctrlrange="0 0.015"/>
  </actuator>

</mujoco>
